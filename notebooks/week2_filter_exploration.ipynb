#!/usr/bin/env python3
"""
Week 2 - Biological Filtering
==============================
Filters K. pneumoniae proteome to realistic drug target candidates.

Strategy:
  1. Remove proteins that are too short or too long (undruggable)
  2. Remove human homologs using BLAST (would cause toxicity if targeted)
  3. Keep only essential genes (must survive, so great drug targets)
  4. Output a clean FASTA of candidate targets

Usage:
    python scripts/02_filter_targets.py

Outputs:
    results/filtered_targets.fasta
    results/filtering_report.md
    visualizations/filtering_funnel.png
"""

import os
import subprocess
import requests
import time
from pathlib import Path
from datetime import datetime
from Bio import SeqIO
import pandas as pd
import matplotlib.pyplot as plt
import matplotlib.patches as mpatches
import seaborn as sns


sns.set_theme(style="whitegrid", palette="muted")
plt.rcParams["figure.dpi"] = 120


def log(msg):
    print(f"[{datetime.now().strftime('%H:%M:%S')}] {msg}")


def save_file(content, path):
    Path(path).parent.mkdir(parents=True, exist_ok=True)
    with open(path, "w") as f:
        f.write(content)
    log(f"Saved: {path}")


# ── Config (matches config.yaml) ───────────────────────────────────────────────
MIN_LEN = 50
MAX_LEN = 2000
BLAST_EVALUE = 1e-5
BLAST_IDENTITY = 30   # proteins with >30% identity to human = too risky


# ── Step 1: Load proteome ──────────────────────────────────────────────────────
def load_proteome(fasta_path="data/proteome.fasta"):
    log(f"Loading proteome from {fasta_path}...")
    records = list(SeqIO.parse(fasta_path, "fasta"))
    log(f"Loaded {len(records)} proteins")
    return records


# ── Step 2: Length filter ──────────────────────────────────────────────────────
def filter_by_length(records):
    """
    Remove very short (<50 aa) and very large (>2000 aa) proteins.
    - Short: no druggable pockets, likely signal peptides / fragments
    - Large: computationally expensive, rarely have clean binding sites
    """
    log(f"\nStep 1: Length filter ({MIN_LEN}-{MAX_LEN} aa)...")

    kept = [r for r in records if MIN_LEN <= len(r.seq) <= MAX_LEN]
    removed = len(records) - len(kept)

    log(f"  Removed: {removed} proteins (too short or too long)")
    log(f"  Kept:    {len(kept)} proteins")
    return kept


# ── Step 3: Essential gene filter ─────────────────────────────────────────────
def filter_essential(records, essential_path="data/essential_genes.txt"):
    """
    Cross-reference with DEG essential genes list.
    Only proteins whose gene name matches a known essential gene are kept.

    Why: essential genes = lethal if disrupted = ideal drug targets.
    Non-essential proteins can be bypassed by the bacteria.
    """
    log(f"\nStep 2: Essential gene filter...")

    # Load essential genes
    with open(essential_path) as f:
        essential = set(
            line.strip().lower()
            for line in f
            if line.strip() and not line.startswith("#")
        )
    log(f"  Essential gene list: {len(essential)} genes")

    # Match by gene name in FASTA header (format: GN=xxxxx)
    essential_records = []
    non_essential = []

    for rec in records:
        gene = ""
        if "GN=" in rec.description:
            gene = rec.description.split("GN=")[1].split(" ")[0].lower()

        if gene and gene in essential:
            essential_records.append(rec)
        else:
            non_essential.append(rec)

    log(f"  Essential proteins matched: {len(essential_records)}")
    log(f"  Non-essential removed:      {len(non_essential)}")
    return essential_records


# ── Step 4: Human homolog removal (BLAST) ─────────────────────────────────────
def remove_human_homologs(records):
    """
    Removes proteins with significant similarity to human proteome.
    Uses BLAST locally if available, otherwise uses UniProt API as fallback.

    Why this matters: if a K. pneumoniae protein looks like a human protein,
    a drug that inhibits it will also inhibit the human version → toxicity.
    This is the most critical safety filter in drug discovery.
    """
    log(f"\nStep 3: Human homolog removal...")

    # Check if BLAST is installed
    blast_available = _check_blast()

    if blast_available:
        log("  BLAST found — running local alignment")
        return _blast_filter(records)
    else:
        log("  BLAST not found — using UniProt taxonomy filter as fallback")
        log("  (Install BLAST for proper homolog removal: conda install -c bioconda blast)")
        return _uniprot_taxonomy_filter(records)


def _check_blast():
    try:
        result = subprocess.run(
            ["blastp", "-version"],
            capture_output=True, text=True, timeout=5
        )
        return result.returncode == 0
    except (FileNotFoundError, subprocess.TimeoutExpired):
        return False


def _blast_filter(records):
    """
    Full BLAST-based human homolog removal.
    Requires: BLAST installed + human proteome downloaded.
    """
    human_db = "data/human_proteome_db"
    human_fasta = "data/human_proteome.fasta"

    # Download human proteome if not present
    if not os.path.exists(human_fasta):
        log("  Downloading human proteome from UniProt...")
        _download_human_proteome(human_fasta)

    # Build BLAST database from human proteome
    if not os.path.exists(human_db + ".pin"):
        log("  Building BLAST database...")
        subprocess.run([
            "makeblastdb",
            "-in", human_fasta,
            "-dbtype", "prot",
            "-out", human_db
        ], check=True, capture_output=True)
        log("  BLAST database built")

    # Write query FASTA
    query_path = "data/query_targets.fasta"
    SeqIO.write(records, query_path, "fasta")

    # Run BLAST
    blast_out = "results/blast_human_hits.txt"
    log(f"  Running BLAST ({len(records)} queries vs human proteome)...")
    log(f"  This may take 5-15 minutes depending on your machine...")

    subprocess.run([
        "blastp",
        "-query",    query_path,
        "-db",       human_db,
        "-out",      blast_out,
        "-outfmt",   "6 qseqid sseqid pident evalue bitscore",
        "-evalue",   str(BLAST_EVALUE),
        "-perc_identity", str(BLAST_IDENTITY),
        "-num_threads", "4",
        "-max_target_seqs", "1"
    ], check=True)

    # Parse BLAST results — collect human-similar IDs to REMOVE
    human_similar = set()
    if os.path.exists(blast_out) and os.path.getsize(blast_out) > 0:
        blast_df = pd.read_csv(blast_out, sep="\t", header=None,
                               names=["qid","sid","pident","evalue","bitscore"])
        # Remove if identity > threshold
        hits = blast_df[blast_df["pident"] >= BLAST_IDENTITY]
        human_similar = set(hits["qid"].tolist())
        log(f"  Human homologs found: {len(human_similar)} proteins")

    # Filter
    filtered = [r for r in records if r.id not in human_similar]
    log(f"  Removed: {len(human_similar)} human homologs")
    log(f"  Kept:    {len(filtered)} non-human-homolog targets")
    return filtered


def _download_human_proteome(out_path):
    """Downloads the reviewed human proteome from UniProt."""
    url = (
        "https://rest.uniprot.org/uniprotkb/stream"
        "?format=fasta"
        "&query=proteome:UP000005640+AND+reviewed:true"
    )
    try:
        response = requests.get(url, timeout=180)
        response.raise_for_status()
        with open(out_path, "w") as f:
            f.write(response.text)
        n = response.text.count(">")
        log(f"  Downloaded {n} human proteins")
    except Exception as e:
        log(f"  Could not download human proteome: {e}")


def _uniprot_taxonomy_filter(records):
    """
    Fallback when BLAST is not installed.
    Removes a curated list of protein families known to be conserved
    between bacteria and humans (based on literature).

    Note: for your final project, install BLAST and run the real filter.
    This fallback gives a reasonable approximation.
    """
    # Protein families/keywords that are highly conserved in humans
    # These would be flagged by BLAST and removed
    human_conserved_keywords = [
        "atp synthase",       # highly conserved across all life
        "rna polymerase",     # eukaryotic version very similar
        "dna polymerase",     # core replication machinery
        "elongation factor",  # translation factors
        "chaperonin",         # groEL homolog = human HSP60
        "heat shock",         # highly conserved
        "superoxide dismutase",
        "thioredoxin",
        "glutaredoxin",
        "ferredoxin",
    ]

    filtered = []
    removed_count = 0

    for rec in records:
        desc_lower = rec.description.lower()
        is_conserved = any(kw in desc_lower for kw in human_conserved_keywords)
        if is_conserved:
            removed_count += 1
        else:
            filtered.append(rec)

    log(f"  Removed (conserved families): {removed_count} proteins")
    log(f"  Kept: {len(filtered)} proteins")
    log("  NOTE: Install BLAST for proper homolog removal:")
    log("        conda install -c bioconda blast")
    return filtered


# ── Step 5: Save results ───────────────────────────────────────────────────────
def save_results(records, out_path="results/filtered_targets.fasta"):
    Path(out_path).parent.mkdir(parents=True, exist_ok=True)
    SeqIO.write(records, out_path, "fasta")
    size_kb = os.path.getsize(out_path) / 1024
    log(f"\nFiltered targets saved: {out_path} ({size_kb:.1f} KB)")
    log(f"Total candidate drug targets: {len(records)}")


# ── Step 6: Visualize the filtering funnel ────────────────────────────────────
def plot_funnel(counts, labels):
    """
    Classic drug discovery funnel — shows how many proteins survive each filter.
    """
    fig, axes = plt.subplots(1, 2, figsize=(13, 5))

    # Left: horizontal bar funnel
    colors = ["#4A90D9", "#5BAD8F", "#E05C3A", "#F5A623"]
    bars = axes[0].barh(
        range(len(counts)), counts,
        color=colors[:len(counts)], edgecolor="white", linewidth=0.8
    )
    axes[0].set_yticks(range(len(labels)))
    axes[0].set_yticklabels(labels, fontsize=11)
    axes[0].set_xlabel("Number of proteins")
    axes[0].set_title("Filtering funnel", fontsize=13)
    axes[0].invert_yaxis()

    # Add count labels on bars
    for bar, count in zip(bars, counts):
        axes[0].text(
            bar.get_width() + 30, bar.get_y() + bar.get_height() / 2,
            f"{count:,}", va="center", fontsize=10, fontweight="bold"
        )

    # Right: percentage retained at each step
    pcts = [c / counts[0] * 100 for c in counts]
    axes[1].plot(range(len(pcts)), pcts, "o-",
                 color="#4A90D9", linewidth=2, markersize=8)
    for i, (pct, label) in enumerate(zip(pcts, labels)):
        axes[1].annotate(
            f"{pct:.1f}%",
            (i, pct),
            textcoords="offset points",
            xytext=(0, 10),
            ha="center", fontsize=10
        )
    axes[1].set_xticks(range(len(labels)))
    axes[1].set_xticklabels(labels, rotation=15, ha="right", fontsize=10)
    axes[1].set_ylabel("% of original proteome retained")
    axes[1].set_title("Retention at each filter step", fontsize=13)
    axes[1].set_ylim(0, 115)

    plt.suptitle("K. pneumoniae — Drug Target Filtering Pipeline", fontsize=14, fontweight="bold")
    plt.tight_layout()

    out = "visualizations/filtering_funnel.png"
    Path("visualizations").mkdir(exist_ok=True)
    plt.savefig(out, dpi=150, bbox_inches="tight")
    plt.show()
    log(f"Funnel plot saved: {out}")


# ── Step 7: Write markdown report ─────────────────────────────────────────────
def write_report(counts, labels, final_records):
    # Build gene name list for the report
    gene_names = []
    for rec in final_records[:20]:
        if "GN=" in rec.description:
            gene = rec.description.split("GN=")[1].split(" ")[0]
            gene_names.append(gene)

    report = f"""# Week 2 - Filtering Report
Generated: {datetime.now().strftime('%Y-%m-%d %H:%M')}

## Filter summary
| Step | Proteins remaining | Removed |
|------|--------------------|---------|
"""
    for i, (label, count) in enumerate(zip(labels, counts)):
        removed = (counts[i-1] - count) if i > 0 else 0
        report += f"| {label} | {count:,} | {removed:,} |\n"

    report += f"""
## Final candidate set
- **{len(final_records)} drug target candidates** selected from {counts[0]:,} total proteins
- Retention rate: {len(final_records)/counts[0]*100:.1f}% of proteome

## Biological reasoning
1. **Length filter**: removes fragments and mega-complexes with no druggable sites
2. **Essential genes**: lethal when disrupted = guaranteed target validity
3. **Human homolog removal**: critical safety step — prevents designing toxic drugs

## Top candidates (first 20)
{', '.join(gene_names)}

## Next step - Week 3
Run: `python scripts/03_feature_engineering.py`
This will extract ML features (AA composition, hydrophobicity, charge, etc.)
from each candidate protein.
"""
    save_file(report, "results/filtering_report.md")


# ── Main ───────────────────────────────────────────────────────────────────────
def main():
    print("=" * 55)
    print(" Week 2 - Biological Filtering")
    print(f" {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
    print("=" * 55 + "\n")

    # Track counts at each step for the funnel plot
    counts = []
    labels = []

    # Load
    records = load_proteome()
    counts.append(len(records))
    labels.append("Full proteome")

    # Filter 1: length
    records = filter_by_length(records)
    counts.append(len(records))
    labels.append("Length filter")

    # Filter 2: essential genes
    records = filter_essential(records)
    counts.append(len(records))
    labels.append("Essential genes")

    # Filter 3: human homologs
    records = remove_human_homologs(records)
    counts.append(len(records))
    labels.append("Human homologs removed")

    # Save
    save_results(records)

    # Visualize
    plot_funnel(counts, labels)

    # Report
    write_report(counts, labels, records)

    print("\n" + "=" * 55)
    print(f" Week 2 complete!")
    print(f" Drug target candidates: {len(records)}")
    print(f" Saved to: results/filtered_targets.fasta")
    print(f" Next: python scripts/03_feature_engineering.py")
    print("=" * 55)


if __name__ == "__main__":
    main()